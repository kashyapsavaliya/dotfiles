window-decoration = true
window-theme = "dark"
window-save-state = always
window-padding-x = 10
# maximize window
window-height = 9999
window-width = 9999

# cursor
cursor-style = block
cursor-style-blink = true

font-family = Berkeley Mono Regular
font-family-bold = Berkeley Mono Bold
font-family-italic = Berkeley Mono Oblique
font-family-bold-italic = Berkeley Mono Bold Oblique
font-feature = +calt
font-feature = +ss02
font-size = 20
shell-integration-features = no-cursor,sudo,ssh-terminfo,ssh-env
theme = Catppuccin Mocha

background = "#000000"

# copy pasta
clipboard-read = "allow"
clipboard-paste-protection = false
